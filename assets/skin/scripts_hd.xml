<screen name="Scripts" position="0,0" size="1280,720" backgroundColor="transparent" flags="wfNoBorder" title="Scripts">

    <!-- Background -->
    <ePixmap position="0,0" zPosition="-1" size="1280,720"
        pixmap="/usr/lib/enigma2/python/Plugins/Extensions/ElieSatPanelGrid/assets/background/panel_bg.jpg"/>

    <!-- Top bar -->
    <eLabel position="0,0" size="1280,90" zPosition="10" backgroundColor="#000000" />

    <!-- Title -->
    <eLabel text="● Scripts Manager – Run, manage and control your scripts"
        position="230,0" size="900,40" zPosition="11"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" />

    <!-- Left / Right black bars -->
    <eLabel position="0,90" size="50,580" zPosition="10" backgroundColor="#000000" />
    <eLabel position="1230,90" size="50,580" zPosition="10" backgroundColor="#000000" />

    <!-- Script list (10 items) -->
    <widget name="list"
        position="70,160"
        size="760,400"
        itemHeight="40"
        font="Bold;24"
        halign="center"
        valign="center"
        foregroundColor="yellow"
        foregroundColorSelected="orange"
        selectionPixmap="/usr/lib/enigma2/python/Plugins/Extensions/ElieSatPanelGrid/assets/icon/selection.png"
        scrollbarMode="showOnDemand"
        transparent="1" />

    <!-- Selected script -->
    <widget name="script_name"
        position="70,570"
        size="760,35"
        zPosition="12"
        font="Bold;26"
        halign="center"
        valign="center"
        foregroundColor="#FF8C00"
        backgroundColor="#000000"
        transparent="1" />

    <!-- Select instruction (moved under script name) -->
    <eLabel text="Select and press OK to execute"
        position="70,605"
        size="760,30"
        zPosition="12"
        font="Regular;22"
        halign="center"
        valign="center"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1" />

    <!-- Page indicator -->
    <widget name="page_info"
        position="1040,520"
        size="200,40"
        zPosition="12"
        font="Bold;24"
        halign="center"
        valign="center"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1" />

    <!-- Date -->
    <widget source="global.CurrentTime" render="Label"
        position="900,100" size="350,25"
        font="Bold;24"
        halign="center"
        valign="center"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1">
        <convert type="ClockToText">Format %A %d %B</convert>
    </widget>

    <!-- Clock -->
    <widget source="global.CurrentTime" render="Label"
        position="900,130" size="350,25"
        font="Bold;24"
        halign="center"
        valign="center"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1">
        <convert type="ClockToText">Format %H:%M:%S</convert>
    </widget>

    <!-- System info -->
    <widget name="image_name" position="950,280" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <widget name="python_ver" position="950,310" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <widget name="local_ip" position="950,340" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <widget name="StorageInfo" position="950,370" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <widget name="RAMInfo" position="950,400" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <widget name="net_status" position="950,430" size="300,25"
        font="Bold;24" halign="left" valign="center"
        foregroundColor="yellow" backgroundColor="#000000" transparent="1" />

    <!-- Bottom buttons -->
    <eLabel position="0,717" size="320,3" backgroundColor="red" />
    <widget name="red" position="0,667" size="320,50"
        font="Bold;24" halign="center" valign="center"
        text="Remove List"
        foregroundColor="yellow" backgroundColor="#000000" />

    <eLabel position="320,717" size="320,3" backgroundColor="green" />
    <widget name="green" position="320,667" size="320,50"
        font="Bold;24" halign="center" valign="center"
        text="Update List"
        foregroundColor="yellow" backgroundColor="#000000" />

    <eLabel position="640,717" size="320,3" backgroundColor="yellow" />
    <widget name="yellow" position="640,667" size="320,50"
        font="Bold;24" halign="center" valign="center"
        text="Background run"
        foregroundColor="yellow" backgroundColor="#000000" />

    <eLabel position="960,717" size="320,3" backgroundColor="blue" />
    <widget name="blue" position="960,667" size="320,50"
        font="Bold;24" halign="center" valign="center"
        text="Restart Enigma2"
        foregroundColor="yellow" backgroundColor="#000000" />

    <!-- Vertical bars -->
    <widget name="left_bar"
        position="15,110"
        size="40,500"
        zPosition="20"
        font="Regular;18"
        halign="center"
        valign="top"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1"
        noWrap="1" />

    <widget name="right_bar"
        position="1240,110"
        size="40,500"
        zPosition="20"
        font="Regular;18"
        halign="center"
        valign="top"
        foregroundColor="yellow"
        backgroundColor="#000000"
        transparent="1"
        noWrap="1" />

</screen>
